html {
  font-size: 14px;
}

@media (min-width: 768px) {
  html {
    font-size: 16px;
  }
}

.btn:focus, .btn:active:focus, .btn-link.nav-link:focus, .form-control:focus, .form-check-input:focus {
  box-shadow: 0 0 0 0.1rem white, 0 0 0 0.25rem #258cfb;
}

html {
  position: relative;
  min-height: 100%;
}

body {
    margin-bottom: 60px;
    background-image: url('/Images/background.jpeg');
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
}

#mensajeExito {
    animation: fadeInOut 4s ease-in-out;
}

@keyframes fadeInOut {
    0% {
        opacity: 0;
        transform: translateY(-20px);
    }

    10% {
        opacity: 1;
        transform: translateY(0);
    }

    90% {
        opacity: 1;
    }

    100% {
        opacity: 0;
        transform: translateY(-20px);
    }
}

:root {
    /* Aumentado tamaño del sobre: ajustar valores aquí si quieres más/menos */
    --env-width: 500px; /* antes 260px */
    --env-height: 300px; /* antes 160px */
    /* Colores dorados para la solapa (flap) */
    --flap-color-a: #f6f6f6; /* dorado claro */
    --flap-color-b: #4C9141; /* dorado oscuro para degradado */
    --overlay-bg: radial-gradient(circle at center, rgba(0,0,0,0.45), rgba(0,0,0,0.7));
}

#envelopeOverlay {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--overlay-bg);
    z-index: 1050;
    transition: opacity 360ms ease;
    -webkit-tap-highlight-color: transparent;
    will-change: opacity;
}

    #envelopeOverlay.fade-out {
        opacity: 0;
        pointer-events: none;
    }

.envelope {
    width: var(--env-width);
    height: var(--env-height);
    perspective: 800px;
    cursor: pointer;
    position: relative;
    transform-style: preserve-3d;
    user-select: none;
}

    .envelope .body {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: 70%;
        background: #fff;
        border-radius: 6px;
        box-shadow: 0 8px 28px rgba(0,0,0,0.32);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        color: #333;
        will-change: transform, opacity;
        transform: translateZ(0);
    }

    .envelope .flap {
        position: absolute;
        left: 0;
        right: 0;
        top: 0;
        height: 70%;
        transform-origin: top center;
        background: linear-gradient(180deg, var(--flap-color-a), var(--flap-color-b));
        border-top-left-radius: 8px;
        border-top-right-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.05rem;
        box-shadow: 0 6px 18px rgba(0,0,0,0.22);
        will-change: transform;
        transform: rotateX(0deg);
    }

    /* inner decorative panel (letter) */
    .envelope .inner {
        position: absolute;
        top: 14%;
        left: 6%;
        right: 6%;
        bottom: 12%;
        background: linear-gradient(180deg,#D9EED8,#D9EED8);
        border-radius: 3px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #666;
        pointer-events: none;
    }

    /* Animation: flap open (GPU-friendly transforms) */
    .envelope.open .flap {
        animation: flapOpen 700ms cubic-bezier(.2,.9,.2,1) forwards;
    }

@keyframes flapOpen {
    0% {
        transform: rotateX(0deg);
    }

    60% {
        transform: rotateX(-120deg);
    }

    100% {
        transform: rotateX(-180deg);
    }
}

/* Ocultar el contenido principal hasta que se abra */
#mainContent {
    opacity: 0;
    transform: scale(0.99);
    transition: opacity 420ms ease, transform 420ms ease;
    will-change: opacity, transform;
}

    #mainContent.visible {
        opacity: 1;
        transform: scale(1);
    }

/* Preferencias de reducción de movimiento */
@media (prefers-reduced-motion: reduce) {
    .envelope.open .flap {
        animation: none;
        transform: rotateX(-180deg);
    }

    #envelopeOverlay, #mainContent {
        transition: none;
    }
}

/* Responsive */
@media (max-width: 576px) {
    :root {
        /* Tamaño móvil reducido */
        --env-width: 300px; /* antes 200px */
        --env-height: 180px; /* antes 120px */
    }

    /* Para móviles usa una imagen optimizada: crea una versión webp
       (por ejemplo /Images/background-small.webp) y colócala en wwwroot/Images
       para mejorar rendimiento. Si no existe, el navegador usará la ruta
       definida fuera de este media query (background.jpeg). */
    body {
        background-image: url('/Images/background-small.webp');
        background-position: center;
        background-size: cover;
        background-attachment: scroll;
    }
}
