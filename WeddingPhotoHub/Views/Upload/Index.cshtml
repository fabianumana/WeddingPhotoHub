@model List<WeddingPhotoHub.Models.Foto>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Subir Foto";
}

<div id="envelopeOverlay" role="button" aria-label="Abrir invitación" tabindex="0">
    <div class="envelope" id="pageEnvelope" aria-hidden="false">
        <div class="flap">Abrir</div>
        <div class="body">Nuestra Boda</div>
        <div class="inner">💌 Haz clic para entrar</div>
    </div>
</div>

<div id="mainContent" aria-hidden="true">
    <div class="container mt-5">
        <div class="card shadow p-4">

            <h2 class="text-center mt-4">💍 Nuestra Boda</h2>
            <p class="text-center">Comparte tus recuerdos con nosotros 📸</p>

            @if (TempData["Error"] != null)
            {
                <p style="color:red;">@TempData["Error"]</p>
            }

            @if (TempData["Mensaje"] != null)
            {
                <p style="color:green;">@TempData["Mensaje"]</p>
            }

            <form asp-action="Subir" method="post" enctype="multipart/form-data" class="text-center mt-4">
                @Html.AntiForgeryToken()

                <div class="d-flex flex-column gap-3 mb-3">

                    <!-- 📸 TOMAR FOTO O VIDEO -->
                    <label class="btn btn-success btn-lg">
                        📸 Tomar Foto o Video
                        <input type="file"
                               name="archivos"
                               multiple
                               capture="environment"
                               accept="image/*,video/*"
                               onchange="previewImages(event)"
                               hidden>
                    </label>

                    <!-- 🖼 ELEGIR DESDE GALERÍA -->
                    <label class="btn btn-primary btn-lg">
                        🖼 Elegir desde Galería
                        <input type="file"
                               name="archivos"
                               multiple
                               accept="image/*,video/*"
                               onchange="previewImages(event)"
                               hidden>
                    </label>

                </div>

                <div id="previewContainer"
                     class="d-flex flex-wrap justify-content-center gap-2 mb-3"></div>

                <button type="submit" class="btn btn-primary btn-lg px-5">
                    Compartir Recuerdos
                </button>
            </form>

            <h3 class="mt-5 text-center">📸 Galería</h3>

            <div class="gallery-grid mt-4">

                @if (Model?.Any() == true)
                {
                    foreach (var foto in Model)
                    {
                        <div class="gallery-item">

                            @if (foto.ContentType != null && foto.ContentType.StartsWith("video"))
                            {
                                <video controls
                                       class="img-fluid rounded-top preview-video"
                                       preload="metadata">
                                    <source src="@foto.Url" type="@foto.ContentType" />
                                </video>
                            }
                            else
                            {
                                <img src="@foto.Url"
                                     class="img-fluid rounded-top preview-img"
                                     loading="lazy"
                                     onclick="openModal('@foto.Url', 'image')" />
                            }

                        </div>
                    }
                }
                else
                {
                    <div class="text-center">
                        <p>Aún no hay fotos... ¡sé el primero! 📸</p>
                    </div>
                }

            </div>

        </div>

        <a href="/Auth/Login" class="admin-hidden-link">⚙️</a>
    </div>
</div>

<script>
    /* =========================
       OVERLAY (ENVELOPE)
    ========================= */
    (() => {
        const overlay = document.getElementById('envelopeOverlay');
        const envelope = document.getElementById('pageEnvelope');
        const main = document.getElementById('mainContent');

        if (!overlay || !envelope || !main) return;

        overlay.style.zIndex = '9999';

        const FALLBACK_MS = 1400;
        let opened = false;

        const openPage = () => {
            if (opened) return;
            opened = true;

            envelope.classList.add('open');

            const finish = () => {
                overlay.classList.add('fade-out');
                overlay.style.pointerEvents = 'none';

                setTimeout(() => overlay.remove(), 300);

                main.classList.add('visible');
                main.setAttribute('aria-hidden', 'false');
            };

            envelope.addEventListener('animationend', finish, { once: true });
            setTimeout(finish, FALLBACK_MS);
        };

        overlay.addEventListener('click', openPage);
        envelope.addEventListener('click', e => {
            e.stopPropagation();
            openPage();
        });

        overlay.addEventListener('keydown', e => {
            if (e.key === 'Enter' || e.key === ' ') {
                e.preventDefault();
                openPage();
            }
        });

        overlay.tabIndex = 0;
    })();

    /* =========================
       PREVIEW IMAGES
    ========================= */
    let selectedFiles = [];

    function previewImages(event) {

        const container = document.getElementById('previewContainer');

        const files = Array.from(event.target.files);

        files.forEach(file => {

            selectedFiles.push(file);

            const fileURL = URL.createObjectURL(file);

            if (file.type.startsWith('image')) {

                const img = document.createElement('img');

                img.src = fileURL;

                Object.assign(img.style, {
                    width: '120px',
                    height: '120px',
                    objectFit: 'cover',
                    borderRadius: '10px',
                    boxShadow: '0 2px 8px rgba(0,0,0,0.2)'
                });

                container.appendChild(img);
            }

            else if (file.type.startsWith('video')) {

                const video = document.createElement('video');

                video.src = fileURL;

                video.controls = true;
                video.muted = true;

                Object.assign(video.style, {
                    width: '120px',
                    height: '120px',
                    objectFit: 'cover',
                    borderRadius: '10px',
                    boxShadow: '0 2px 8px rgba(0,0,0,0.2)'
                });

                container.appendChild(video);
            }

        });
    }

    /* =========================
       MODAL (UNA SOLA FUNCIÓN)
    ========================= */
        function openModal(src, type = 'image') {

        const modal = document.createElement('div');

        Object.assign(modal.style, {
            position: 'fixed',
            inset: '0',
            background: 'rgba(0,0,0,0.9)',
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'center',
            zIndex: '99999',
            cursor: 'zoom-out'
        });

        if (type === 'video') {

            const video = document.createElement('video');

            video.src = src;
            video.controls = true;
            video.autoplay = true;

            Object.assign(video.style, {
                maxWidth: '90%',
                maxHeight: '90%',
                borderRadius: '12px'
            });

            modal.appendChild(video);
        }
        else {

            const img = document.createElement('img');

            img.src = src;

            Object.assign(img.style, {
                maxWidth: '90%',
                maxHeight: '90%',
                borderRadius: '12px'
            });

            modal.appendChild(img);
        }

        modal.addEventListener('click', () => modal.remove());

        document.body.appendChild(modal);
    }
</script>
