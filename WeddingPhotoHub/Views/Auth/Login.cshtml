@model WeddingPhotoHub.Models.LoginVM

<header>
    <link rel="stylesheet" href="~/css/login.css" />
</header>

<div class="login-container">
    <div class="login-card">

        <h2 class="mb-2">WeddingPhotoHub</h2>
        <p class="mb-3">💍 Acceso privado</p>

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3 text-start">
                <label asp-for="Username" class="form-label"></label>
                <input asp-for="Username" class="form-control" autocomplete="username" placeholder="Usuario" required />
            </div>

            <div class="mb-3 text-start">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" type="password" class="form-control" autocomplete="current-password" placeholder="Contraseña" required />
            </div>

            <button type="submit" class="btn btn-login w-100">Ingresar</button>
        </form>

        @if (!ViewData.ModelState.IsValid)
        {
            <p class="text-danger mt-3">Credenciales incorrectas</p>
        }

    </div>
</div>