@model List<WeddingPhotoHub.Models.Foto>

<link rel="stylesheet" href="~/css/admin.css" />

<div class="admin-container">

    <div class="admin-header">
        <h2>📸 Panel Admin</h2>
        <p>Bienvenido @User.Identity.Name</p>
        <a class="logout-btn" href="/Auth/Logout">Cerrar Sesión</a>
    </div>

    @if (TempData["Mensaje"] != null)
    {
        <div class="alert success">@TempData["Mensaje"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert error">@TempData["Error"]</div>
    }

    <div class="gallery">
        @foreach (var foto in Model)
        {
            <div class="card">

                @if (foto.ContentType != null && foto.ContentType.StartsWith("video"))
                {
                    <video controls
                           class="img-card"
                           onclick="openModal('@foto.Url', 'video')">

                        <source src="@foto.Url" type="@foto.ContentType" />

                    </video>
                }
                else
                {
                    <img src="@foto.Url"
                         class="img-card preview-img"
                         onclick="openModal('@foto.Url', 'image')" />
                }

                <div class="actions">

                    <form method="post" action="/Admin/Descargar" target="_blank">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@foto.Id" />
                        <button type="submit">⬇ Descargar</button>
                    </form>

                    <form method="post" action="/Admin/Eliminar">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@foto.Id" />
                        <button type="submit">🗑 Eliminar</button>
                    </form>

                </div>

            </div>
        }
    </div>

</div>

<script>

    function openModal(src, type = 'image') {

        const existing = document.getElementById('media-modal');

        if (existing) {
            existing.remove();
        }

        const modal = document.createElement('div');

        modal.id = 'media-modal';

        Object.assign(modal.style, {
            position: 'fixed',
            inset: '0',
            background: 'rgba(0,0,0,0.9)',
            display: 'flex',
            alignItems: 'center',
            justifyContent: 'center',
            zIndex: '99999',
            cursor: 'zoom-out'
        });

        if (type === 'video') {

            const video = document.createElement('video');

            video.src = src;
            video.controls = true;
            video.autoplay = true;

            Object.assign(video.style, {
                maxWidth: '90%',
                maxHeight: '90%',
                borderRadius: '12px'
            });

            modal.appendChild(video);
        }
        else {

            const img = document.createElement('img');

            img.src = src;

            Object.assign(img.style, {
                maxWidth: '90%',
                maxHeight: '90%',
                borderRadius: '12px'
            });

            modal.appendChild(img);
        }

        modal.addEventListener('click', () => modal.remove());

        document.body.appendChild(modal);
    }

</script>